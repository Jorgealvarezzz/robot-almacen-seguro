# ============================================================
# Variables de entorno - EJEMPLO
# Copiar a .env y ajustar valores reales. NO subir .env a Git.
# ============================================================

# --- MQTT Broker ---
MQTT_HOST=mosquitto
MQTT_PORT_TLS=8883
MQTT_USER=robot
MQTT_PASSWORD=robotpass_cambiame

# --- Backend JWT ---
# Generar uno nuevo con: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=CAMBIAR_POR_SECRETO_FUERTE_GENERADO_ALEATORIAMENTE
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=30

# --- Backend DB ---
DB_PATH=/data/robot.db

# --- Usuarios precargados (solo para demo; en producción usar IdP real) ---
ADMIN_USER=admin
ADMIN_PASSWORD=admin123
OPERADOR_USER=operador
OPERADOR_PASSWORD=op123
